---
import BaseLayout from "../../layouts/Base.astro";
import { getCollection } from 'astro:content';

import Card from "../../components/portfolio/Card.astro";

import wallpaperImage from "@assets/images/wallpaper.jpg";

const featured_posts = await getCollection('portfolio', ({ data }) => {
return data.featured === true;
});

const posts = (await getCollection('portfolio')).sort(
(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout>
  <div class="bg-[url()] backdrop-blur-xl bg-cover">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <h1 class="text-6xl font-bold text-white text-center py-10">
        Portfolio
      </h1>

      <div class="flex justify-center gap-x-5">
        <a href="https://github.com/zoulhadj" type="button" class="inline-flex items-center rounded-md  bg-teal-500 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" target="_blank">
          GitHub
        </a>
        <a href="https://stackoverflow.com/users/13159482/zoulhadj" type="button" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" target="_blank">
          Stack Overflow
        </a>
        <a href="https://leetcode.com/ZOulhadj/" type="button" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" target="_blank">
          LeetCode
        </a>
        <a href="https://www.linkedin.com/in/zoulhadj/" type="button" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" target="_blank">
          LinkedIn
        </a>
        <a href="/portfolio/CV.pdf" type="button" class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" target="_blank">
          CV
        </a>
      </div>

      <div class="mb-10">
        <div class="relative mt-2 rounded-md shadow-sm">
          <input type="text" name="price" id="price" class="block w-full rounded-md border-0 py-1.5 pr-20 text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6" placeholder="Search..." disabled>
        </div>
      </div>

      <div class="mb-5">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900">
          Featured Work
        </h2>
        <div class="mt-6 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
          {
              featured_posts.map((post) => (
                  <Card post={post} />
              ))
          }
        </div>
      </div>
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-gray-900">
          All Work
        </h2>
        <div class="mt-6 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 xl:gap-x-8">
          {
          posts.map((post) => (
          <Card post={post}/>
          ))
          }
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
