---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import BaseSimple from "@layouts/BaseSimple.astro";
import Link from "@components/Link.astro";

import aboutImage from "@assets/images/me.jpg";

import cv_pdf from "@assets/files/CV.pdf";

const about = {
    name: "Zakariya Oulhadj",
    title: "🎓 MSc. High Performance Computing @ The University of Edinburgh",
    location: "📍 London, United Kingdom",
    socials: [
        { name: "LinkedIn", url: "https://linkedin.com/in/zoulhadj" },
        { name: "GitHub", url: "https://github.com/zoulhadj" },
        { name: "OCRID", url: "https://orcid.org/0009-0003-9722-6283" }
    ],
    caption: "Hardware is only as good as the software that drives it"
};

// Get most recent posts from latest to oldest
const max_items = 5;

const blog_collection = await getCollection("blog");

const all_public_posts = blog_collection
    .filter((post) => { return !post.data.draft;})
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = all_public_posts.slice(0, max_items);

const should_read_more = all_public_posts.length > max_items;

---

<BaseSimple>
    <div class="flex gap-4">
        <div class="">
            <figure>
                <Image
                    src={aboutImage}
                    class="border border-gray-400 mb-2"
                    width={200}
                    alt="My avatar"
                    loading="eager"
                />
                <figcaption class="text-center italic text-xs w-[200px] text-gray-600 dark:text-gray-200">
                    "{about.caption}"
                </figcaption>
            </figure>
        </div>
        <div class="text-black dark:text-white">
            <h1 class="font-bold text-2xl">
                {about.name}
            </h1>
            <h1 class="bold">
                {about.title}
            </h1>
            <h1 class="">
                {about.location}
            </h1>
            <div class="flex gap-4">
                {
                  about.socials.map((item) => (
                    <Link href={item.url}>
                        {item.name}
                    </Link>
                  ))
                }
            </div>
        </div>
    </div>

    <div class="my-10">
        <h1 class="font-bold text-2xl text-black dark:text-white">
            Recent posts
        </h1>
        <ol class="flex flex-col mb-5">
            {
            posts.map((post) => (
            <li class="flex gap-2">
                <div class="flex justify-between w-24 text-sm text-gray-500">
                    <span>
                        {post.data.pubDate.toLocaleDateString("en-GB", {year: "numeric", month: "2-digit", day: "2-digit", })}
                    </span>
                    <span>
                        &mdash;
                    </span>
                </div>
                <Link href={`/blog/${post.slug}`}>
                    {post.data.title}
                </Link>
             </li>
             ))
             }
        </ol>

        { should_read_more && 
            <Link href={`/blog`}>
                Read more
            </Link>
        }
    </div>
</BaseSimple>
