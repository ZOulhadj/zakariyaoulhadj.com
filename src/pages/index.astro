---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

import BaseSimple from "@layouts/BaseSimple.astro";
import Link from "@components/Link.astro";
import Button from "@components/Button.astro";

import aboutImage from "@assets/images/me.jpg";

const about = {
    name: "BSc. Zakariya Oulhadj",
    title: "Graduate Software Engineer",
    location: "London, United Kingdom",
    socials: {
        LinkedIn: "https://google.com"
    },
    caption: "\"Hardware is only as good as the software that drives it\""
};

// Get all posts from latest to oldest
const all_posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const posts = all_posts.filter((post) => {
    return !post.data.draft;
});

---

<BaseSimple>
    <div class="flex gap-4">
        <div class="">
            <Image
                src={aboutImage}
                class="border border-gray-400 mb-2"
                width={200}
                alt="Profile picture"
            />
            <figcaption class="text-center italic text-xs w-[200px] text-gray-600 dark:text-gray-200">
                {about.caption}
            </figcaption>
        </div>
        <div class="text-black dark:text-white">
            <h1 class="font-bold text-xl">
                {about.name}
            </h1>
            <h1 class="bold">
                {about.title}
            </h1>
            <h1 class="">
                {about.location}
            </h1>
            <div class="flex gap-4">
                <Link href="https://linkedin.com/in/zoulhadj" target="_blank">LinkedIn</Link>
                <Link href="https://github.com/zoulhadj" target="_blank">GitHub</Link>
                <Link href="https://orcid.org/0009-0003-9722-6283" target="_blank">ORCID</Link>
            </div>
        </div>
    </div>

    <!-- <p> -->
    <!--   I am a First Class with Honours (BSc) Computer Science graduate -->
    <!--   from <Link href="https://roehampton.ac.uk" target="_blank" -->
    <!--              >The University of Roehampton</Link -->
    <!--                                             >. Some of my key interests include Computer Graphics, Real-Time -->
    <!--   Simulations, Low-Level Software Architecture, and the -->
    <!--   development of time-critical applications that require -->
    <!--   efficiency and precision. Proficient in various programming -->
    <!--   languages but most notably in modern C++ (with over 5 years of -->
    <!--   experience), Python and full-stack web development. I'm an -->
    <!--   individual who is keen to learn and explore new ideas and -->
    <!--   technologies. -->
    <!-- </p> -->

    <div class="my-10">
        <h1 class="font-bold text-2xl text-black dark:text-white">
            Recent posts
        </h1>
        <ul class="mb-5">
            {
            posts.map((post) => (
            <li class="flex items-center gap-2">
                <div class="text-sm text-gray-500">
                    {post.data.pubDate.toLocaleDateString("en-GB", {year: "numeric", month: "2-digit", day: "2-digit", })}
                </div>
                <span class="text-gray-500">
                    &mdash;
                </span>
                <Link href={`/post/`}>Post</Link>
                <!-- <Link href={`/posts/${post.slug}`}>
                {post.data.title}
                </Link>
                -->
                </li>
                ))
                }
        </ul>
</BaseSimple>
