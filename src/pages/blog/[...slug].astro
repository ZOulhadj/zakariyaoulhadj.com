---
import { getCollection } from "astro:content";
import Link from "@components/Link.astro";
import BaseSimple from "@layouts/BaseSimple.astro";

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

---

<BaseSimple>
    <div class="dark:text-white text-black lg:w-4/6 mb-10">
        <h1 class="bold text-4xl mb-1">
            {entry.data.title}
        </h1>
        <!-- <h1 class="bold text-4xl mb-1" style="font-family: 'Alegreya', serif;">
            {entry.data.title}
        </h1> -->
        <h4 class="mb-5">
            {entry.data.description}
        </h4>
        <div class="text-sm">
            <h4 class="mb-2">
                Published by <Link href="/">{entry.data.author}</Link> on {entry.data.pubDate.toLocaleDateString("en-GB", {day: "numeric", month: "long", year: "numeric", })}
            </h4>
            <div class="flex gap-2">
                { entry.data.tags.map((tag) => (
                    <Link href={`/blog/tags/${tag}`} class="capitalize">
                        {tag}
                    </Link>
                ))}
            </div>
        </div>
    </div>
    <div class="flex">
        <article class="prose dark:prose-invert max-w-none text-black dark:text-white">
            <Content />
        </article>
    </div>
    
</BaseSimple>
