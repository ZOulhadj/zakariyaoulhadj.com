---
import BaseLayout from "../../layouts/Base.astro";

import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import PostTags from "../../components/PostTags.astro";

const posts = (await getCollection('blog')).sort(
(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout>
  <div class="">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl py-16 sm:py-24 lg:max-w-none lg:py-32">
        <h2 class="text-2xl font-bold text-gray-900">
          Blog Posts
        </h2>
        <div class="mt-6 space-y-12 lg:grid lg:grid-cols-3 lg:gap-x-6 lg:space-y-0">
          {
          posts.map((post) => (

          <div class="">
            <a href={`/blog/posts/${post.slug}/`} class="hover:underline decoration-2 group">
              <div class="relative aspect-w-16 aspect-h-9 overflow-hidden rounded-lg bg-white">
                <img src={post.data.heroImage} alt={post.data.description} class="h-full w-full object-cover object-center group-hover:opacity-90">
              </div>


              <p class="mt-4 text-base font-semibold text-gray-900">
                {post.data.title}
              </p>
            </a>
            
            <h3 class="text-sm text-gray-500 underline-0 mb-2">
              <FormattedDate date={post.data.pubDate} />
            </h3>
            
            <PostTags tags={post.data.tags} />
          </div>

          ))
          }
        </div>
      </div>
    </div>
</BaseLayout>

