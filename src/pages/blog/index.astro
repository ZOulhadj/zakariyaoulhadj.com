---
import { getCollection } from 'astro:content';

import BaseLayout from "@layouts/Base.astro";

import FormattedDate from '@components/FormattedDate.astro';
import PostTags from "@components/PostTags.astro";

// Get all posts from latest to oldest
const all_posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Return all non-draft posts
const posts = all_posts.filter((post) => { return !post.data.draft; });

---
<BaseLayout>
    <div class="">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
                <h1 class="text-6xl font-bold text-black text-center py-10">
                    Blog
                </h1>
                <div class="flex flex-col justify-center divide-y">
                    {
posts.map((post) => (

  <div class="w-full px-5 py-1.5">
    <a href={`/blog/posts/${post.slug}/`} class="hover:underline decoration-2 group">
      <!-- <div class="relative aspect-w-16 aspect-h-9 overflow-hidden rounded-lg bg-white">
      <img src={post.data.heroImage} alt={post.data.description} class="h-full w-full object-cover object-center group-hover:opacity-90">
      </div> -->


      <p class="text-base font-semibold text-gray-900">
        {post.data.title}
      </p>
    </a>

    <!-- <h3 class="text-sm text-gray-500 underline-0 mb-2"> -->
    <!--   <FormattedDate date={post.data.pubDate} /> -->
    <!-- </h3> -->
  </div>

))
}
                </div>
            </div>
        </div>
</BaseLayout>
