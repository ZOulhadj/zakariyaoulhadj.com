---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

  <html lang="en">
    <head>
      <BaseHead title={title} description={description} />
    </head>

    <body>
      <Header />
      <main>
        <article class="px-4 py-24 mx-auto max-w-7xl" itemid="#" itemscope itemtype="http://schema.org/BlogPosting">
          <div class="w-full mx-auto mb-12 text-left md:w-3/4 lg:w-1/2">
            <img src={heroImage} class="object-cover w-full h-64 bg-center rounded-lg" alt="Kutty" />
            <p class="mt-6 mb-2 text-xs font-semibold tracking-wider uppercase text-primary">
              Technology
            </p>
            <h1 class="mb-3 text-3xl font-bold leading-tight text-gray-900 md:text-4xl" itemprop="headline" title={title}>
              {title}
            </h1>
            <div class="flex mb-6 space-x-2 text-sm">
              {
              tags.map((tag) => (
              <a class="text-gray-900 bg-gray-100 badge rounded-full hover:bg-gray-200 px-2" href="#">
                {tag.charAt(0).toUpperCase() + tag.slice(1) }
              </a>              
              ))
              }
            </div>
            <a class="flex items-center text-gray-700" href="/">
              <div class="rounded-full w-10 h-10 avatar">
                <img src="/me.jpg" alt="Photo of Zakariya Oulhadj" />
              </div>
              <div class="ml-2">
                <p class="text-sm font-semibold text-gray-800">
                  Zakariya Oulhadj
                </p>
                <p class="text-sm text-gray-500">
                  <FormattedDate date={pubDate} />
                </p>
              </div>
            </a>
          </div>

          <div class="w-full mx-auto prose md:w-3/4 lg:w-1/2">
            <slot />
          </div>
        </article>

      </main>
      <Footer />
    </body>
  </html>
