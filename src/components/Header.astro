---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---
<header class="bg-white border-b">
  <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
    <a href="/" class="decoration-2 text-xl">
      <div class="font-bold" style="font-family: 'baby blocks', monospaced;">
        {SITE_TITLE}
      </div>
    </a>
    <div class="flex md:space-x-8 space-x-3">
      <HeaderLink href="/" class="text-sm font-semibold leading-6 text-gray-900 hover:underline">Home</HeaderLink>
      <HeaderLink href="/portfolio" class="text-sm font-semibold leading-6 text-gray-900 hover:underline">Portfolio</HeaderLink>
      <HeaderLink href="/blog" class="text-sm font-semibold leading-6 text-gray-900 hover:underline">Blog</HeaderLink>
      <!-- <HeaderLink href="/gallery" class="text-sm font-semibold leading-6 text-gray-900 hover:underline">Gallery</HeaderLink> -->
    </div>
  </nav>
</header>
