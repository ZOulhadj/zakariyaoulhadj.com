---
import HeaderLink from './HeaderLink.astro';

import ThemeToggle from "@components/ThemeToggle.astro";

import { SITE_TITLE } from '../consts';
---
<header class="bg-white dark:bg-slate-800 border-b">
    <nav class="mx-auto flex max-w-7xl items-center justify-between p-6 lg:px-8" aria-label="Global">
        <a href="/" class="font-bold text-gray-900 dark:text-white decoration-2 text-xl">
                {SITE_TITLE}
        </a>
        <div class="flex md:space-x-8 space-x-3">
            <HeaderLink href="/" class="text-sm font-semibold leading-6 text-gray-900 dark:text-white hover:underline">
                Home
            </HeaderLink>
            <HeaderLink href="/portfolio" class="text-sm font-semibold leading-6 text-gray-900 dark:text-white hover:underline">
                Portfolio
            </HeaderLink>
            <HeaderLink href="/blog" class="text-sm font-semibold leading-6 text-gray-900 dark:text-white hover:underline">
                Blog
            </HeaderLink>
            <HeaderLink href="/gallery" class="text-sm font-semibold leading-6 text-gray-900 dark:text-white hover:underline">
                Gallery
            </HeaderLink>
        </div>
        <ThemeToggle />
    </nav>
</header>
