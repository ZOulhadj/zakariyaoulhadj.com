---

const {tags} = Astro.props;
---

<div class="flex space-x-2 text-sm">
  {
  tags.map((tag: string) => (
  <a class="text-gray-900 bg-gray-100 badge rounded-full hover:bg-gray-200 px-2" href={`/blog/tags/${tag}/`}>
    {tag.charAt(0).toUpperCase() + tag.slice(1) }
  </a>              
  ))
  }
</div>
