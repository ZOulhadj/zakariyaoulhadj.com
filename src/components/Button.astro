---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
---

<a href={href} class:list={["focus:-translate-y-12 bg-green-700 hover:border-b-4 hover:border-black text-white px-2 py-1.5", className]} {...props}>
    <slot />
</a>
